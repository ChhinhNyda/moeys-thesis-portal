// MoEYS National Thesis Archive — database schema (Phase 2 v1)
// See: project_phase2_schema.md in the auto-memory for the locked spec.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── HEI (Higher Education Institution) ─────────────────────────────

enum HeiType {
  PUBLIC
  PRIVATE
  INTERNATIONAL
}

model Hei {
  id           String   @id @default(cuid())
  name         String
  nameKhmer    String?
  shortCode    String   @unique
  type         HeiType
  // Supervising ministry code — most HEIs report to MoEYS, but some are
  // under MAFF (agriculture), MoH (health), MCFA (fine arts), MoLVT
  // (vocational), etc. The full list of valid codes lives in the prototype's
  // SUPERVISING_MINISTRIES; expand to a Ministry table if it ever grows.
  ministry     String   @default("MoEYS")
  city         String?
  contactEmail String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  theses Thesis[]
  users  User[]

  @@map("HEI")
}

// ─── Auth (Auth.js v5 with Prisma adapter + email magic link) ───────
// User, Account, Session, VerificationToken are the Auth.js-required
// shapes. We extend User with `role` and an optional `heiId` for HEI
// Coordinators. Authors do not have accounts — they only receive
// notification emails.

enum UserRole {
  ADMIN              // MoEYS Admin (super)
  REVIEWER           // MoEYS Reviewer (DRI staff who decide)
  HEI_COORDINATOR    // HEI library/research office staff who submit
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(HEI_COORDINATOR)
  heiId         String?
  hei           Hei?      @relation(fields: [heiId], references: [id])
  // Invitation-only: new accounts default to inactive. Admin must
  // explicitly set isActive=true (via the seed script or admin UI)
  // before a user can sign in. Auto-created rows from a magic-link
  // attempt by an unknown email land here with isActive=false and are
  // rejected by the signIn callback.
  isActive      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

// Account is required by the Prisma adapter even when only using email
// magic link — it's used to link external auth providers if added later.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Thesis ─────────────────────────────────────────────────────────

enum DegreeLevel {
  MASTERS
  PHD
}

enum ThesisLanguage {
  ENGLISH
  KHMER
  OTHER
}

enum ThesisStatus {
  DRAFT
  UNDER_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
  WITHDRAWN
}

enum ReleasePolicy {
  IMMEDIATE
  DELAY_6M
  DELAY_1Y
  DELAY_2Y
  DELAY_3Y
  DELAY_5Y
}

enum ReleaseReason {
  PATENT
  PUBLICATION
  COMMERCIAL
  SENSITIVE
  OTHER
}

enum License {
  ALL_RIGHTS_RESERVED
  CC_BY
  CC_BY_NC
  CC_BY_NC_ND
}

enum Visibility {
  PUBLIC
  METADATA_ONLY
  HIDDEN
}

model Thesis {
  id String @id @default(cuid())

  // Metadata
  title         String
  titleKhmer    String?
  abstract      String         @db.Text
  abstractKhmer String?        @db.Text
  keywords      String[]
  language      ThesisLanguage
  pageCount     Int?

  // Author (plain text fields; will link to User in Phase 3)
  authorFirstName String
  authorLastName  String
  authorEmail     String?

  // Academic context
  degreeLevel       DegreeLevel
  fieldOfStudy      String
  defenseYear       Int
  supervisorName    String
  coSupervisorNames String[]

  // HEI relationship
  heiId String
  hei   Hei    @relation(fields: [heiId], references: [id])

  // Workflow
  status          ThesisStatus @default(DRAFT)
  submittedAt     DateTime     @default(now())
  approvedAt      DateTime?
  rejectionReason String?      @db.Text

  // Author rights (per locked policy)
  releasePolicy        ReleasePolicy
  releaseReason        ReleaseReason?
  releaseJustification String?        @db.Text
  publicReleaseAt      DateTime?
  license              License
  licenseAcknowledged  Boolean        @default(false)
  authorshipConfirmed  Boolean        @default(false)

  // Public visibility (daily job updates this)
  visibility Visibility @default(METADATA_ONLY)

  // PDF storage reference (real R2 keys come in Phase 2.5)
  pdfFileKey String?

  // For Cambodian scholars who studied abroad. heiId points at the
  // special "INDEP" HEI bucket; the actual foreign institution name and
  // country live here. Both are null for normal Cambodian-HEI submissions.
  externalInstitutionName String?
  externalCountry         String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
